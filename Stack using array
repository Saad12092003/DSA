#include <bits/stdc++.h>
using namespace std;

#define MAX 4
int arr[MAX];
int top = -1;

void push(int val) {
    if (top == MAX - 1) {
        cout << "Stack Overflow!" << endl;
        return;
    }
    top++;
    arr[top] = val;

}


void pop() {
    if (top == -1) {
        cout << "Stack Underflow!" << endl;
        return ;
    }

    top--;

}
bool isempty()
{
    return top == -1;
}
void print() {


    for (int i = 0; i<= top; i++) {
        cout << arr[i] << " ";
    }
    cout << endl;
}

int main() {
    push(100);
    push(200);
    push(30);
    push(40);

    pop();
    pop();

    push(300);
    push(200);
    pop();

    print();

    return 0;
}
